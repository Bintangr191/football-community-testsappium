# ─── Appium Server ──────────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ─── Android Device ─────────────────────────────────────────────────
# Dari output `adb devices`
# Untuk emulator: emulator-5554
# Untuk physical device: ganti dengan UDID (contoh: R5CRA1JXXXXX)
DEVICE_NAME=emulator-5554
DEVICE_UDID=emulator-5554

# Android version (misal: 14 untuk Android 14)
ANDROID_VERSION=14

# ─── API Backend ────────────────────────────────────────────────────
# Dari emulator Android ke host machine:
#   10.0.2.2 = localhost komputer host (untuk AVD standar)
# Dari physical device:
#   Gunakan IP LAN komputer kamu (contoh: 192.168.1.100)
API_BASE_URL=http://10.0.2.2:3000

# ─── Test Credentials ───────────────────────────────────────────────
# User yang sudah terdaftar untuk test login
TEST_USER_EMAIL=testuser@kickoff.test
TEST_USER_PASSWORD=password123

# User untuk test registrasi (pastikan belum terdaftar / dihapus setelah test)
TEST_REGISTER_EMAIL=newuser_auto@kickoff.test
TEST_REGISTER_PASSWORD=password123

# ─── Deeplink Expo ──────────────────────────────────────────────────
# URL deeplink Expo Go untuk membuka app langsung
# Format: exp://IP:PORT atau exp+slug://
# Sesuaikan dengan IP LAN dan port Expo dev server kamu
EXPO_DEEPLINK=exp://10.0.2.2:8081

# ─── Logging ────────────────────────────────────────────────────────
# Level: trace | debug | info | warn | error | silent
LOG_LEVEL=info
